# ===================================================================
# .gitignore for AI Code Security Auditor
# Protects sensitive data and reduces repository size
# ===================================================================

# ===================================================================
# SENSITIVE DATA - NEVER COMMIT THESE!
# ===================================================================

# Environment variables with API keys and secrets
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
*.env

# API Keys and credentials
*_api_key*
*_secret*
*credentials*
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# AWS credentials
.aws/
aws-credentials.json

# Config files with sensitive data
config/secrets.yml
config/database.yml
config/credentials.yml

# ===================================================================
# PYTHON
# ===================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.whl

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# pdm
.pdm.toml

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments - Virtual Environments (LARGE!)
env/
venv/
ENV/
env.bak/
venv.bak/
myenv/
.venv/
virtualenv/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# ===================================================================
# NODE.JS / JAVASCRIPT
# ===================================================================

# Dependencies (VERY LARGE!)
node_modules/
jspm_packages/
bower_components/

# npm
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ===================================================================
# DATABASES & DATA FILES
# ===================================================================

# SQLite databases
*.db
*.sqlite
*.sqlite3
*.db-journal

# PostgreSQL
*.pgsql

# MySQL
*.sql
*.mysql

# MongoDB
*.mongodb

# ChromaDB / Vector Databases (LARGE!)
chroma_db/
*.chroma
vectordb/

# Redis dumps
dump.rdb
appendonly.aof

# Database backups
*.backup
*.bak
*.dump

# ===================================================================
# MACHINE LEARNING / AI MODELS (VERY LARGE!)
# ===================================================================

# Downloaded models
models/
*.pkl
*.pickle
*.h5
*.hdf5
*.pb
*.pth
*.pt
*.ckpt
*.safetensors
*.bin
*.onnx

# Hugging Face cache
.cache/huggingface/
.cache/torch/

# Sentence Transformers cache (LARGE!)
.cache/sentence_transformers/

# Model weights
weights/
checkpoints/

# Training data
training_data/
dataset/

# ===================================================================
# IDE / EDITOR SETTINGS
# ===================================================================

# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Eclipse
.settings/
.classpath
.project

# NetBeans
nbproject/private/
build/
nbbuild/
dist/
nbdist/

# JetBrains
.idea/
*.iml

# ===================================================================
# OPERATING SYSTEM FILES
# ===================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*
.nfs*

# ===================================================================
# BUILD ARTIFACTS & TEMPORARY FILES
# ===================================================================

# Build directories
build/
dist/
out/
target/
.gradle/
.next/
.nuxt/
.cache/

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.cache

# Log files (can be large!)
*.log
logs/
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test output files
test_output/
test_results/
test-results/
coverage/
.nyc_output/

# Compiled files
*.class
*.o
*.obj
*.exe
*.dll
*.dylib
*.so
*.com

# Archives (can be large!)
*.zip
*.tar
*.gz
*.rar
*.7z
*.tgz
*.bz2
*.xz

# ===================================================================
# PROJECT-SPECIFIC
# ===================================================================

# Test files (keep structure but ignore outputs)
tests/temp_files/*
!tests/temp_files/.gitkeep

tests/chroma_db/
tests/test_chroma_db/

# Generated reports
*.sarif
*_report.json
*_report.md
security_report.*
audit_report.*
results.json

# Backups
backup/
backups/

# User-specific test files
user_test_*.py
scratch_*.py
temp_*.py

# Large media files
*.mp4
*.avi
*.mov
*.mp3
*.wav

# Documentation build
docs/_build/
docs/.doctrees/

# ===================================================================
# CI/CD & DEPLOYMENT
# ===================================================================

# Docker
.dockerignore
docker-compose.override.yml

# Terraform
*.tfstate
*.tfstate.backup
.terraform/

# Kubernetes secrets
*-secret.yaml
*-secrets.yaml

# Deployment configs with secrets
deploy-secrets.yml
production.yml

# ===================================================================
# MISC
# ===================================================================

# Jupyter notebooks with outputs
*.ipynb_checkpoints

# R
.Rhistory
.RData
.Rproj.user

# MATLAB
*.asv

# Local configuration overrides
local.config
local_config.py
config.local.js

# Uploaded files
uploads/
user_uploads/

# Generated files
generated/
auto_generated/

# Editor backups
*.bak
*~

# ===================================================================
# KEEP THESE FILES (Exceptions)
# ===================================================================

# Keep .gitkeep files in empty directories
!.gitkeep

# Keep example/template files
!example.env
!.env.example
!.env.template
!config.example.yml

# Keep important documentation
!README.md
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md

# ===================================================================
# END OF .gitignore
# ===================================================================
