# AI Code Security Auditor Configuration
# Copy this file to .env and fill in your API keys

# =================================
# API Keys (Choose at least one)
# =================================

# OpenRouter API Key (Recommended - gives access to multiple models)
# Get from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API Key (Optional - for direct OpenAI access)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# =================================
# Model Configuration
# =================================

# Default model to use for analysis
DEFAULT_MODEL=openai/gpt-4

# OpenAI specific model (when using OpenAI directly)
OPENAI_MODEL=gpt-4

# =================================
# Application Configuration
# =================================

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Scanning Configuration
MAX_FILE_SIZE_MB=10
SCAN_TIMEOUT_SECONDS=300

# Output Configuration
DEFAULT_OUTPUT_FORMAT=table

# =================================
# Optional: Advanced Configuration
# =================================

# GitHub Integration (Optional)
# GITHUB_TOKEN=your_github_token_here

# Custom API URLs (Usually not needed)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# OPENAI_BASE_URL=https://api.openai.com/v1