# AI Code Security Auditor - Environment Configuration

# ============================================================================
# Required: OpenRouter Configuration (for AI features)
# ============================================================================
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenRouter API Configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_REFERER=http://localhost:8001
OPENROUTER_TITLE="AI Code Security Auditor"

# Available Models (comma-separated list)
OPENROUTER_MODELS=agentica-org/deepcoder-14b-preview:free,moonshotai/kimi-dev-72b:free,qwen/qwen-2.5-coder-32b-instruct:free,meta-llama/llama-3.3-70b-instruct:free

# ============================================================================
# Optional: GitHub Integration
# ============================================================================
# GitHub personal access token for repository integration
GITHUB_TOKEN=ghp_your_token_here

# GitHub webhook secret for secure webhook handling
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# Database Configuration
# ============================================================================
# SQLite database for application data
DATABASE_URL=sqlite:///./security_auditor.db

# ChromaDB vector database directory for RAG
CHROMA_PERSIST_DIRECTORY=./chroma_db

# ============================================================================
# Application Configuration
# ============================================================================
# API server configuration
API_HOST=0.0.0.0
API_PORT=8001

# Security scanner tool paths (optional - uses system PATH by default)
BANDIT_CONFIG_PATH=./configs/bandit.yaml
SEMGREP_RULES_PATH=./configs/semgrep-rules

# ============================================================================
# Production Configuration (optional)
# ============================================================================
# Environment mode
ENVIRONMENT=development

# Logging level
LOG_LEVEL=INFO

# Enable debug mode
DEBUG=false

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001

# ============================================================================
# Docker Configuration (optional)
# ============================================================================
# Docker Compose environment variables
COMPOSE_PROJECT_NAME=ai-security-auditor
COMPOSE_FILE=docker-compose.yml

# Production Docker configuration
# COMPOSE_FILE=docker-compose.prod.yml